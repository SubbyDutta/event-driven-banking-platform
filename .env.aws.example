# ============================================================================
# .env.aws.example — production env template for AWS deploy.
#
# Copy to .env.aws ON THE EC2 (NEVER commit .env.aws), fill in every __FILL__.
# This file is safe to commit because it contains no real secrets.
#
# Authentication: do NOT set AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY.
# The EC2 instance role provides credentials via instance metadata.
# Do NOT set AWS_ENDPOINT_URL — when unset, boto3/AWS SDK hits real AWS.
# ============================================================================

# ---------- AWS region ------------------------------------------------------
AWS_REGION=ap-south-1
AWS_DEFAULT_REGION=ap-south-1

# ---------- RDS Postgres endpoint -------------------------------------------
RDS_HOST=__RDS_ENDPOINT__.ap-south-1.rds.amazonaws.com

# ---------- Per-service DB URLs (same host, different DBs) ------------------
DATABASE_URL=jdbc:postgresql://${RDS_HOST}:5432/subbybank
POSTGRES_USER=subby
POSTGRES_PASSWORD=__FILL__

FINDOC_DATABASE_URL=postgresql+asyncpg://findoc:__FILL__@${RDS_HOST}:5432/findoc
FINDOC_ALEMBIC_DATABASE_URL=postgresql+psycopg2://findoc:__FILL__@${RDS_HOST}:5432/findoc
FINDOC_POSTGRES_USER=findoc
FINDOC_POSTGRES_PASSWORD=__FILL__
FINDOC_POSTGRES_DB=findoc

SUBBY_LOAN_DATABASE_URL=postgresql+asyncpg://subbyloan:__FILL__@${RDS_HOST}:5432/subby_loan
SUBBY_LOAN_ALEMBIC_DATABASE_URL=postgresql+psycopg2://subbyloan:__FILL__@${RDS_HOST}:5432/subby_loan

# ---------- S3 (one bucket, all services) -----------------------------------
S3_BUCKET=subby-prod-documents-XXXX
SUBBY_S3_BUCKET=subby-prod-documents-XXXX
FINDOC_DOCUMENTS_BUCKET=subby-prod-documents-XXXX
S3_REGION=ap-south-1

# ---------- Redis ----------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379

# ---------- SNS / SQS — keep names identical to local LocalStack ------------
SUBBY_LOAN_SQS_QUEUE=subby-risk-requests
SUBBY_LOAN_SNS_TOPIC_RESULT=subby-risk-result

# ---------- Gmail SMTP ------------------------------------------------------
# Generate the 16-char app password at:
#   https://myaccount.google.com/apppasswords  (requires 2-Step Verification)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=__YOUR_GMAIL_ADDRESS__
MAIL_PASSWORD=__16_CHAR_APP_PASSWORD_NO_SPACES__
MAIL_FROM=__YOUR_GMAIL_ADDRESS__

# ---------- Inter-service URLs (Docker DNS within compose network) ----------
FINDOC_BASE_URL=http://findoc-verify:8000
FINDOC_API_KEY=__GENERATE_RANDOM_32_CHAR__
SUBBY_PYTHON_LOAN_URL=http://subby-python-loan:8000
FRAUD_ML_URL=http://fraud-python:8001
LOAN_CHECK_URL=http://subby-python-loan:8000

# ---------- Frontend URL (used for CORS + email links) ----------------------
FRONTEND_URL=https://__YOUR_FRONTEND_DOMAIN__
FRONTEND_ORIGIN=https://__YOUR_FRONTEND_DOMAIN__

# ---------- Spring Boot secrets ---------------------------------------------
JWT_SECRET=__GENERATE_RANDOM_32_BYTE_STRING__
ADMINUSER=admin
ADMINPASSWORD=__STRONG_PASSWORD__
MYSECRETKEY=__32_HEX_CHARS__
FIXED=__16_HEX_CHARS__

# ---------- Razorpay --------------------------------------------------------
RAZORPAY_KEY_ID=rzp_test_or_live_xxx
RAZORPAY_SECRET=__FILL__

# ---------- Gemini / LLM ----------------------------------------------------
GEMINI_API_KEY=__FILL__
GEMINI=${GEMINI_API_KEY}
LLM_PROVIDER=gemini
GEMINI_MODEL=gemini-2.0-flash

# ---------- Google Document AI ----------------------------------------------
# secrets/google-sa.json is mounted at /app/secrets/google-sa.json by compose.
GOOGLE_APPLICATION_CREDENTIALS=/app/secrets/google-sa.json
GOOGLE_PROJECT_ID=__FILL__
GOOGLE_DOCAI_LOCATION=asia-south1
GOOGLE_DOCAI_PROCESSOR_ID=__FILL__
OCR_PROVIDER=google_docai

# ---------- SubbyPythonLoan tuning ------------------------------------------
SUBBY_LOAN_MODEL_VERSION=v1.0.0
SUBBY_LOAN_POD_APPROVE_THRESHOLD=0.15
SUBBY_LOAN_POD_REJECT_THRESHOLD=0.35

# ---------- Runtime / workers -----------------------------------------------
APP_ENV=production
APP_PORT=8000
LOG_LEVEL=INFO
WORKER_POLL_WAIT_SECONDS=20
WORKER_BATCH_SIZE=5
WORKER_MAX_RETRIES=3
