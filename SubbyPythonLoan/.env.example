# ---------- SubbyPythonLoan (async SQS consumer) --------------------------

APP_ENV=development
APP_PORT=8000
LOG_LEVEL=INFO

# Dedicated Postgres database (created by infra/postgres-init.sql in the monorepo
# compose; standalone users can provision it themselves).
DATABASE_URL=postgresql+asyncpg://subbyloan:subbyloan@postgres:5432/subby_loan
ALEMBIC_DATABASE_URL=postgresql+psycopg2://subbyloan:subbyloan@postgres:5432/subby_loan

# LocalStack for dev; unset AWS_ENDPOINT_URL in prod to use real AWS (and supply
# real credentials). Everything else stays the same — no code change.
AWS_ENDPOINT_URL=http://localstack:4566
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

SQS_QUEUE=subby-risk-requests
SNS_TOPIC_RESULT=subby-risk-result

MODEL_PATH=/app/loan_model.pkl
SCALER_PATH=/app/scaler.pkl
MODEL_VERSION=v1.0.0

POD_APPROVE_THRESHOLD=0.15
POD_REJECT_THRESHOLD=0.35

WORKER_POLL_WAIT_SECONDS=20
WORKER_BATCH_SIZE=5
