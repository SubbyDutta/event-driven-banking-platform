# --- App ---
APP_ENV=development
APP_PORT=8000
LOG_LEVEL=INFO
FRONTEND_ORIGIN=http://localhost:8000
ADMIN_BOOTSTRAP_MODE=true

# --- Database ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/findoc
ALEMBIC_DATABASE_URL=postgresql+psycopg2://postgres:postgres@postgres:5432/findoc

# --- Storage (LocalStack S3 dev / AWS S3 prod) ---
# For prod AWS: unset S3_ENDPOINT_URL, provide real access keys
S3_ENDPOINT_URL=http://localstack:4566
S3_BUCKET=findoc-documents
S3_ACCESS_KEY=test
S3_SECRET_KEY=test
S3_REGION=ap-south-1

# --- Messaging (LocalStack dev / AWS prod) ---
# For prod AWS: unset AWS_ENDPOINT_URL
AWS_ENDPOINT_URL=http://localstack:4566
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# --- OCR: Google Document AI ---
OCR_PROVIDER=google_docai
GOOGLE_APPLICATION_CREDENTIALS=/app/secrets/google-sa.json
GOOGLE_PROJECT_ID=project-7bb85df2-f684-4eb4-958
GOOGLE_DOCAI_LOCATION=asia-south1
GOOGLE_DOCAI_PROCESSOR_ID=478659c7b8314834

# --- LLM: Gemini 2.0 Flash ---
LLM_PROVIDER=gemini
GEMINI_API_KEY=replace-me
GEMINI_MODEL=gemini-2.0-flash

# --- Worker tuning ---
WORKER_POLL_WAIT_SECONDS=20
WORKER_BATCH_SIZE=5
WORKER_MAX_RETRIES=3
