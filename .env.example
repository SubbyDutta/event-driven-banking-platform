# ============================================================================
# Shared environment for the monorepo docker-compose stack.
#
# Copy to .env and adjust secrets before running `docker compose up`.
#
# Two backend targets are supported for object storage:
#   1. LocalStack S3 (default)  — S3_ENDPOINT_URL=http://localstack:4566
#   2. MinIO                    — S3_ENDPOINT_URL=http://minio:9000
# SNS + SQS always run on LocalStack. Flip S3_ENDPOINT_URL to switch storage
# without touching compose. Buckets exist on both backends so you can swap freely.
# ============================================================================

# ---------- LocalStack (SNS + SQS + optional S3) --------------------------
AWS_REGION=ap-south-1
AWS_DEFAULT_REGION=ap-south-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_ENDPOINT_URL=http://localstack:4566

# ---------- Object storage (S3 / MinIO toggle) ----------------------------
# Point at LocalStack to share one emulator, or MinIO for a dedicated S3-compat server.
#   http://localstack:4566    (default, shared with SNS/SQS)
#   http://minio:9000         (MinIO in this compose)
S3_ENDPOINT_URL=http://localstack:4566
S3_REGION=ap-south-1
S3_ACCESS_KEY=test
S3_SECRET_KEY=test
S3_BUCKET=findoc-documents
SUBBY_S3_BUCKET=subby-documents
FINDOC_DOCUMENTS_BUCKET=findoc-documents

# MinIO root credentials (only used when the minio service is up and buckets are
# being bootstrapped; the apps still talk S3-compatibly via S3_ACCESS_KEY above).
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio12345

# ---------- Shared Postgres (host port 5433) ------------------------------
POSTGRES_SUPER_USER=postgres
POSTGRES_SUPER_PASSWORD=postgres

# SubbyBankbackend
DATABASE_URL=jdbc:postgresql://postgres:5432/subbybank
POSTGRES_USER=subby
POSTGRES_PASSWORD=subby

# findoc-verify (async + alembic)
FINDOC_DATABASE_URL=postgresql+asyncpg://findoc:findoc@postgres:5432/findoc
FINDOC_ALEMBIC_DATABASE_URL=postgresql+psycopg2://findoc:findoc@postgres:5432/findoc
FINDOC_POSTGRES_USER=findoc
FINDOC_POSTGRES_PASSWORD=findoc
FINDOC_POSTGRES_DB=findoc

# SubbyPythonLoan (async SQS consumer)
SUBBY_LOAN_DATABASE_URL=postgresql+asyncpg://subbyloan:subbyloan@postgres:5432/subby_loan
SUBBY_LOAN_ALEMBIC_DATABASE_URL=postgresql+psycopg2://subbyloan:subbyloan@postgres:5432/subby_loan
SUBBY_LOAN_SQS_QUEUE=subby-risk-requests
SUBBY_LOAN_SNS_TOPIC_RESULT=subby-risk-result
SUBBY_LOAN_MODEL_VERSION=v1.0.0
SUBBY_LOAN_POD_APPROVE_THRESHOLD=0.15
SUBBY_LOAN_POD_REJECT_THRESHOLD=0.35

# ---------- Redis ----------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379

# ---------- findoc-verify runtime -----------------------------------------
APP_ENV=development
APP_PORT=8000
LOG_LEVEL=INFO
FRONTEND_ORIGIN=http://localhost:5173
WORKER_POLL_WAIT_SECONDS=20
WORKER_BATCH_SIZE=5
WORKER_MAX_RETRIES=3

# ---------- Google Document AI (OCR) --------------------------------------
# Path is inside the findoc-verify container; mount your service-account JSON at
# ./secrets/google-sa.json and compose will bind it to /app/secrets/google-sa.json.
GOOGLE_APPLICATION_CREDENTIALS=/app/secrets/google-sa.json
GOOGLE_PROJECT_ID=replace-me
GOOGLE_DOCAI_LOCATION=asia-south1
GOOGLE_DOCAI_PROCESSOR_ID=replace-me
OCR_PROVIDER=google_docai

# ---------- Gemini / LLM --------------------------------------------------
GEMINI_API_KEY=replace-me
GEMINI_MODEL=gemini-2.0-flash
LLM_PROVIDER=gemini

# ---------- SubbyBankbackend app secrets ----------------------------------
FINDOC_BASE_URL=http://findoc-verify:8000
FINDOC_API_KEY=local-dev-key
SUBBY_PYTHON_LOAN_URL=http://subby-python-loan:8000

JWT_SECRET=local-dev-jwt-secret-change-me-in-prod-please-32b
ADMINUSER=admin
ADMINPASSWORD=admin

# Integrations (placeholders for local; fill in for real-call paths)
RAZORPAY_KEY_ID=rzp_test_placeholder
RAZORPAY_SECRET=placeholder
FRAUD_ML_URL=http://subby-python-loan:8000
LOAN_CHECK_URL=http://subby-python-loan:8000
FRONTEND_URL=http://localhost:5173
MYSECRETKEY=0123456789abcdef0123456789abcdef
FIXED=0123456789abcdef

# Alias so findoc-verify and SubbyBankbackend can both read the same Gemini key name.
# Java reads `GEMINI`; Python reads `GEMINI_API_KEY` — keep them in lockstep.
GEMINI=${GEMINI_API_KEY}
